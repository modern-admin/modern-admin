root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{js,mjs,cjs,jsx,ts,tsx}]
ij_javascript_spaces_within_imports = true
ij_typescript_spaces_within_imports = true

[*.md]
trim_trailing_whitespace = false
