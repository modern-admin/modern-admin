{
  "name": "@modern-admin/adapter-prisma",
  "version": "0.3.2",
  "description": "Prisma 7 adapter for Modern Admin — implements BaseDatabase/BaseResource on top of PrismaClient.",
  "homepage": "https://github.com/modern-admin/modern-admin/tree/main/packages/adapter-prisma#readme",
  "keywords": [
    "modern-admin",
    "admin",
    "admin-panel",
    "admin-dashboard",
    "prisma",
    "orm",
    "postgres",
    "database"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/adapter-prisma"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-admin/core": "workspace:^"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@prisma/client": "^7.8.0",
    "@types/bun": "^1.3.13",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@prisma/client": "^7.8.0"
  }
}
