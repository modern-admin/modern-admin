{
  "name": "@modern-admin/realtime",
  "version": "0.2.0",
  "description": "WebSocket gateway + realtime bus implementations for Modern Admin.",
  "homepage": "https://github.com/modern-admin/modern-admin/tree/main/packages/realtime#readme",
  "keywords": [
    "modern-admin",
    "admin",
    "admin-panel",
    "admin-dashboard",
    "websocket",
    "realtime",
    "subscriptions"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/realtime"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-admin/core": "workspace:^",
    "@modern-admin/nest": "workspace:^"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/websockets": {
      "optional": true
    },
    "@nestjs/platform-socket.io": {
      "optional": true
    }
  }
}
