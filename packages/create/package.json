{
  "name": "@modern-admin/create",
  "version": "0.2.0",
  "description": "Scaffolder for a standalone @modern-admin admin-panel service. Invoke via `bun create @modern-admin <name>` (or `npm create @modern-admin`).",
  "homepage": "https://github.com/modern-admin/modern-admin/tree/main/packages/create#readme",
  "keywords": [
    "modern-admin",
    "admin",
    "admin-panel",
    "admin-dashboard",
    "cli",
    "scaffold",
    "create",
    "starter"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/create"
  },
  "bin": {
    "create-modern-admin": "./src/cli.ts",
    "modern-admin": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "template"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "create-modern-admin": "./dist/cli.js",
      "modern-admin": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-admin/system-prisma": "workspace:^",
    "@modern-admin/system-drizzle": "workspace:^"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
