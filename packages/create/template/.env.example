# HTTP server
PORT=3001
HOST=0.0.0.0
# CORS origins for the admin panel (comma-separated). Default: allow same-origin only.
# WEB_ORIGIN=http://localhost:3000

# Postgres — admin app reads/writes the SAME database as your main backend.
DATABASE_URL=postgres://{{name}}:{{name}}@localhost:5432/{{name}}

# Redis — used for cross-instance cache invalidation. Optional, falls back
# to in-process cache when unset.
# REDIS_URL=redis://localhost:6379

# Better Auth — required. Generate with: `bun run auth:secret`
BETTER_AUTH_SECRET=replace-me-with-32-random-bytes-hex
BETTER_AUTH_URL=http://localhost:3001

# GitHub Packages auth token (required for `bun install` of @modern-admin/*).
# Create at https://github.com/settings/tokens with `read:packages` scope.
# Surfaced to .npmrc as ${MODERN_ADMIN_TOKEN}.
MODERN_ADMIN_TOKEN=ghp_replace_me
