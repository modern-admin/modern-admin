{
  "name": "@modern-admin/nest",
  "version": "2.0.0",
  "description": "NestJS module wrapping @modern-admin/core — REST controllers, guards, cache, OpenAPI.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/nest"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modern-admin/core": "workspace:*",
    "@modern-admin/i18n": "workspace:*",
    "@modern-admin/queue": "workspace:*",
    "@modern-admin/telemetry": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.177",
    "bullmq": "^5.76.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@nestjs/testing": "^11.1.19",
    "@scalar/nestjs-api-reference": "^1.1.14",
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@scalar/nestjs-api-reference": "^1.1.14",
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@scalar/nestjs-api-reference": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  }
}
