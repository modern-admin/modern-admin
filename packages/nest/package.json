{
  "name": "@modern-admin/nest",
  "version": "0.2.1",
  "description": "NestJS module wrapping @modern-admin/core — REST controllers, guards, cache, OpenAPI.",
  "homepage": "https://github.com/modern-admin/modern-admin/tree/main/packages/nest#readme",
  "keywords": [
    "modern-admin",
    "admin",
    "admin-panel",
    "admin-dashboard",
    "nestjs",
    "rest",
    "openapi",
    "backend"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/nest"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-admin/core": "workspace:^",
    "@modern-admin/i18n": "workspace:^",
    "@modern-admin/queue": "workspace:^",
    "@modern-admin/telemetry": "workspace:^",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "ai": "^7.0.19",
    "bullmq": "^5.80.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@nestjs/testing": "^11.1.19",
    "@scalar/nestjs-api-reference": "^1.1.14",
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@scalar/nestjs-api-reference": "^1.1.14",
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@scalar/nestjs-api-reference": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  }
}
