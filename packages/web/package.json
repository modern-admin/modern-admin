{
  "name": "@modern-admin/web",
  "version": "0.1.1",
  "type": "module",
  "description": "Pre-built React admin SPA. Mount it into a host page or let @modern-admin/nest serve the standalone bundle.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/web"
  },
  "files": [
    "dist",
    "src",
    "index.html",
    "vite.config.ts",
    "tsconfig.json"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./standalone/*": "./dist/standalone/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "./dist/lib/index.js",
    "types": "./dist/lib/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      },
      "./standalone/*": "./dist/standalone/*",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib && vite build --mode standalone",
    "build:lib": "vite build --mode lib",
    "build:standalone": "vite build --mode standalone",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "dependencies": {
    "@modern-admin/core": "workspace:*",
    "@modern-admin/i18n": "workspace:*",
    "@modern-admin/react": "workspace:*",
    "@modern-admin/ui": "workspace:*",
    "@tanstack/react-query": "^5.100.9"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.1"
  }
}
