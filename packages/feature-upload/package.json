{
  "name": "@modern-admin/feature-upload",
  "version": "0.2.1",
  "description": "File upload feature plugin for Modern Admin (local + S3 providers).",
  "homepage": "https://github.com/modern-admin/modern-admin/tree/main/packages/feature-upload#readme",
  "keywords": [
    "modern-admin",
    "admin",
    "admin-panel",
    "admin-dashboard",
    "upload",
    "files",
    "storage",
    "feature"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/feature-upload"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./nest": {
      "types": "./src/nest/index.ts",
      "default": "./src/nest/index.ts"
    },
    "./graphql": {
      "types": "./src/graphql.ts",
      "default": "./src/graphql.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./nest": {
        "types": "./dist/nest/index.d.ts",
        "default": "./dist/nest/index.js"
      },
      "./graphql": {
        "types": "./dist/graphql.d.ts",
        "default": "./dist/graphql.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-admin/core": "workspace:^",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "busboy": "^1.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@modern-admin/graphql": "workspace:*",
    "@modern-admin/nest": "workspace:*",
    "@modern-admin/tsconfig": "workspace:*",
    "@nestjs/swagger": "^11.4.2",
    "@types/bun": "^1.3.13",
    "@types/busboy": "^1.5.4",
    "graphql": "^17.0.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@nestjs/swagger": "^11.4.2",
    "graphql": "^17.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    },
    "graphql": {
      "optional": true
    }
  }
}
