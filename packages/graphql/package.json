{
  "name": "@modern-admin/graphql",
  "version": "0.1.1",
  "description": "Apollo + code-first GraphQL transport for @modern-admin/nest.",
  "homepage": "https://github.com/modern-admin/modern-admin/tree/main/packages/graphql#readme",
  "keywords": [
    "modern-admin",
    "admin",
    "admin-panel",
    "admin-dashboard",
    "graphql",
    "apollo",
    "subscriptions"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/graphql"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-admin/core": "workspace:*",
    "@modern-admin/nest": "workspace:*",
    "busboy": "^1.6.0",
    "dataloader": "^2.2.3",
    "graphql-ws": "^6.0.8",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@types/bun": "^1.3.13",
    "@types/busboy": "^1.5.4",
    "@types/ws": "^8.18.1",
    "graphql": "^16.11.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "graphql": "^16.0.0"
  }
}
