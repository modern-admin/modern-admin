{
  "name": "@modern-admin/graphql",
  "version": "0.1.2",
  "description": "Apollo + code-first GraphQL transport for @modern-admin/nest.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git",
    "directory": "packages/graphql"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "bun ../../scripts/clean.ts dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modern-admin/core": "workspace:*",
    "@modern-admin/nest": "workspace:*",
    "busboy": "^1.6.0",
    "dataloader": "^2.2.3"
  },
  "devDependencies": {
    "@modern-admin/tsconfig": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@types/bun": "^1.3.13",
    "@types/busboy": "^1.5.4",
    "graphql": "^16.11.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "graphql": "^16.0.0"
  }
}
