# Postgres connection — used by both Prisma and Better Auth (single source of truth).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modern_admin

# Where the API listens.
API_PORT=3001
API_HOST=0.0.0.0

# Origin allowed to call /admin/api and /api/auth.
WEB_ORIGIN=http://localhost:3000,http://localhost:5173

# Better Auth public URL (used to build callback links).
AUTH_BASE_URL=http://localhost:3001

# Better Auth signing secret — REQUIRED. Generate with `openssl rand -hex 32`.
# The server refuses to start without a strong (≥32 char) value.
BETTER_AUTH_SECRET=replace-me-with-`openssl rand -hex 32`

SEED_COUNTRIES=false

# Demo admin seeded on first boot.
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=admin12345
DEMO_ADMIN_NAME=Demo Admin

# Optional: Redis for cache + realtime.
# REDIS_URL=redis://localhost:6379
