{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@modern-admin/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "target": "ES2022"
  },
  "include": ["src/**/*"]
}
