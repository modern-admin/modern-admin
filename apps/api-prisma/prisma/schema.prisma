// Reference schema for the Prisma-flavoured demo of Modern Admin.
//
// Three concerns coexist in this single file:
//
//   1. Better Auth tables (Ma*) — wired through `prismaAdapter(prisma)`
//      in `src/auth.ts`. Better Auth's `user/session/account/verification`
//      logical tables are remapped to physical `ma_user/ma_session/...`
//      via `user: { modelName: 'ma_user' }` etc. in `build-better-auth.ts`.
//      Prisma model names use `Ma`-prefixed PascalCase to match. The
//      `apikey` table comes from the api-key plugin (also remapped).
//
//   2. Modern Admin system tables (Ma*) — copy-pasted from
//      `@modern-admin/system-prisma/schema`. The runtime stores reach for
//      these via the default `maLog`/`maWebhook`/… delegates.
//
//   3. Demo business models (Customer, Post) — what the admin panel
//      manages. Replaced by the host's real models in production.
//
// Migration: `bun run prisma:migrate` (dev) or `bun run prisma:deploy` (prod).

generator client {
  provider = "prisma-client"
  // Pin to a project-local output to avoid clobbering global node_modules
  // in a monorepo where multiple Prisma schemas may coexist.
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Demo business models ──────────────────────────────────────────────────

/// Subscription plan for app customers. Replaces the previous
/// `AdminUserRole` enum which conflated panel-access roles with
/// app-customer plans.
enum CustomerTier {
  free
  pro
  enterprise
}

enum Region {
  eu
  us
  asia
}

enum FavoriteKind {
  post
  product
  category
}

model Customer {
  id          String       @id @default(uuid(7))
  email       String       @unique
  name        String
  phone       String?
  tier        CustomerTier @default(free)
  password    String?
  avatarUrl   String?
  websiteUrl  String?
  bio         String?
  score       Float?
  birthday    DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime     @default(now())

  posts    Post[]
  comments Comment[]

  @@map("customer")
}

model Category {
  id          String  @id @default(uuid(7))
  name        String
  displayName String?
  slug        String?
  description String?
  position    Int?
  iconUrl     String?

  posts     Post[]
  products  Product[]
  favorites Favorite[]

  @@map("category")
}

model Tag {
  id         String  @id @default(uuid(7))
  name       String
  slug       String?
  color      String?
  usageCount Int?

  postLinks    PostTag[]
  productLinks ProductTag[]

  @@map("tag")
}

model Post {
  id          String    @id @default(uuid(7))
  title       String
  slug        String?
  excerpt     String?
  body        String?
  authorId    String
  categoryId  String?
  coverUrl    String?
  viewsCount  Int?
  rating      Float?
  metadata    Json?
  published   Boolean   @default(false)
  publishedAt DateTime?

  author    Customer   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments  Comment[]
  tagLinks  PostTag[]
  favorites Favorite[]

  @@index([authorId])
  @@index([categoryId])
  @@map("post")
}

model Comment {
  id        String   @id @default(uuid(7))
  postId    String
  authorId  String
  body      String
  rating    Float?
  createdAt DateTime @default(now())

  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Customer @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@map("comment")
}

model Product {
  id           String    @id @default(uuid(7))
  sku          String?
  name         String
  slug         String?
  summary      String?
  description  String?
  price        Float?
  currencyCode String?
  accentColor  String?
  inStock      Boolean   @default(true)
  quantity     Int?
  rating       Float?
  launchedAt   DateTime?
  thumbnail    String?
  gallery      String[]
  categoryId   String?

  category  Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tagLinks  ProductTag[]
  favorites Favorite[]

  @@index([categoryId])
  @@map("product")
}

model PostTag {
  id      String    @id @default(uuid(7))
  postId  String
  tagId   String
  addedAt DateTime?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId])
  @@map("post_tag")
}

model ProductTag {
  id        String @id @default(uuid(7))
  productId String
  tagId     String
  position  Int?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([tagId])
  @@map("product_tag")
}

model RegionalContent {
  id          String    @id @default(uuid(7))
  name        String
  region      Region    @default(eu)
  titles      Json?
  previews    Json?
  publishedAt DateTime?

  @@map("regional_content")
}

model Favorite {
  id         String       @id @default(uuid(7))
  label      String
  kind       FavoriteKind
  postId     String?
  productId  String?
  categoryId String?
  createdAt  DateTime     @default(now())

  post     Post?     @relation(fields: [postId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("favorite")
}

// ─── Modern Admin system tables ──────────────────────────────────────────
// Generated by `bunx modern-admin generate`. Re-run after upgrading
// `@modern-admin/system-prisma` to pick up new tables. Existing models
// are NEVER rewritten — your column tweaks survive.
model MaUser {
  id            String    @id @default(uuid(7))
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  /// Role id (= name); resolves to a row in `ma_role` for permissions lookup.
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions MaSession[]
  accounts MaAccount[]
  apiKeys  MaApiKey[]

  @@map("ma_user")
}

model MaSession {
  id             String   @id @default(uuid(7))
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  userId         String
  /// Active impersonation source; admin plugin uses this to track
  /// "log in as" sessions so audit logs can attribute the real actor.
  impersonatedBy String?

  user MaUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ma_session")
}

model MaAccount {
  id                    String    @id @default(uuid(7))
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// Hashed password for the email/password strategy. OAuth/passkey rows
  /// leave this null — credentials are encoded in the provider tokens.
  password              String?

  user MaUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ma_account")
}

model MaVerification {
  id         String   @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ma_verification")
}

/// Better Auth api-key plugin storage. `permissions` is a JSON object
/// `{ resourceId: action[] }` consumed by `ModernAdmin.invoke()`'s
/// api-key gate (see also `MaRole.permissions` for the role-based gate —
/// both share the same matching helper).
model MaApiKey {
  id                  String    @id @default(uuid(7))
  configId            String    @default("default")
  name                String?
  start               String?
  prefix              String?
  key                 String
  referenceId         String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(false)
  rateLimitTimeWindow Int?
  rateLimitMax        Int?
  requestCount        Int       @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  permissions         Json?
  metadata            Json?

  user MaUser @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([referenceId])
  @@map("ma_apikey")
}

/// Configurable role with a permissions matrix.
///
/// `permissions` shape: `Record<resourceId, action[]>`, where `'*'` is a
/// wildcard for actions or for a resource key (matches every resource).
/// The `id` doubles as the user-visible role name — there is no separate
/// `name` column. The string in `<panel-user>.role` (e.g. Better Auth's
/// `ma_user.role`) references this `id` so the auth provider can resolve
/// the row and attach `permissions` onto the principal for
/// `ModernAdmin.invoke()` to gate every action.
///
/// Renames are not supported (would orphan every panel admin holding the
/// role); Prisma treats `@id` columns as immutable, so the storage layer
/// enforces this for free. To "rename", clone under a new id and reassign.
model MaRole {
  /// Application code supplies this on insert (`'admin'`, `'editor'`, …)
  /// — there is no `@default(...)` because it's a meaningful business id,
  /// not a surrogate UUID.
  id          String   @id
  description String?
  permissions Json     @default("{}")
  /// Built-in roles are seeded on boot and cannot be deleted via the UI.
  isBuiltin   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ma_role")
}

model MaLog {
  id         String   @id @default(uuid(7))
  resourceId String
  action     String
  recordId   String?
  recordIds  Json?
  userId     String?
  payload    Json?
  result     Json?
  /// Unix-ms timestamp captured at the after-hook.
  at         BigInt
  createdAt  DateTime @default(now())

  @@index([resourceId, action])
  @@index([userId])
  @@index([createdAt])
  @@map("ma_log")
}

model MaWebhook {
  id            String   @id @default(uuid(7))
  name          String
  url           String
  /// JSON array of dotted event names. Validated by `webhookZ`.
  events        Json
  /// Optional resource/model scope. Null means all resources.
  resourceId    String?
  enabled       Boolean  @default(true)
  secret        String?
  /// JSON object of extra HTTP headers.
  headers       Json     @default("{}")
  /// List-page-style filters matched against the mutation snapshot.
  filters       Json     @default("{}")
  /// Optional JSON array of field paths to include in outgoing payload.
  payloadFields Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliveries MaWebhookDelivery[]

  @@map("ma_webhook")
}

model MaWebhookDelivery {
  id             String    @id @default(uuid(7))
  webhookId      String
  event          String
  payload        Json
  status         String
  responseStatus Int?
  responseBody   String?
  error          String?
  attempt        Int       @default(1)
  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?

  webhook MaWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@map("ma_webhook_delivery")
}

model MaConfig {
  /// Surrogate key. Application code MUST generate this with `uuidv7()`
  /// from `@modern-admin/core` before insert (Prisma's `@default(uuid(7))`
  /// generates v4, which the project policy disallows).
  id        String   @id
  scope     String
  /// Empty string for global, userId for user, resourceId for resource.
  scopeId   String   @default("")
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@unique([scope, scopeId, key])
  @@map("ma_config")
}

model MaHistory {
  id             String   @id @default(uuid(7))
  resourceId     String
  recordId       String
  op             String
  userId         String?
  snapshot       Json
  /// Snapshot of the record _before_ this revision was applied. Used by
  /// the history controller's revert endpoint to undo the change.
  snapshotBefore Json?
  createdAt      DateTime @default(now())

  @@index([resourceId, recordId, createdAt])
  @@map("ma_history")
}

model MaAiTask {
  id         String    @id @default(uuid(7))
  kind       String
  resourceId String?
  recordId   String?
  userId     String?
  status     String
  input      Json      @default("{}")
  output     Json?
  error      String?
  /// 0..100 or null for indeterminate progress.
  progress   Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  events MaAiTaskEvent[]

  @@index([kind, status])
  @@index([userId])
  @@index([resourceId, recordId])
  @@map("ma_ai_task")
}

model MaAiTaskEvent {
  id        String   @id @default(uuid(7))
  taskId    String
  type      String
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  task MaAiTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("ma_ai_task_event")
}

model MaCache {
  key       String    @id
  value     Json
  /// JSON array of tag strings.
  tags      Json      @default("[]")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([expiresAt])
  @@map("ma_cache")
}
