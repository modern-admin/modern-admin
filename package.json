{
  "name": "modern-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Universal modern admin panel framework",
  "workspaces": [
    "apps/*",
    "packages/*",
    "!apps/docs"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --filter '!@modern-admin/docs' --filter '*' build",
    "test": "bun --filter '!@modern-admin/docs' --filter '*' test",
    "e2e": "bun run --cwd apps/e2e e2e",
    "typecheck": "bun run --filter '!@modern-admin/docs' --filter '*' typecheck",
    "lint": "bun run --cwd apps/_shared lint && bun run --cwd apps/api lint && bun run --cwd apps/api-prisma lint && bun run --cwd apps/web lint && bun run --cwd apps/e2e lint",
    "docs:dev": "bun --filter @modern-admin/docs dev",
    "docs:build": "bun --filter @modern-admin/docs build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.13",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
