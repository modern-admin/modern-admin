{
  "name": "modern-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Universal modern admin panel framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api-prisma dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:start": "scripts/dev.sh start",
    "dev:stop": "scripts/dev.sh stop",
    "dev:restart": "scripts/dev.sh restart",
    "dev:status": "scripts/dev.sh status",
    "build": "bun run --filter '*' build",
    "test": "bun --filter '*' test",
    "e2e": "bun run --cwd apps/e2e e2e",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "changeset": "changeset",
    "version-packages": "changeset version && bun scripts/sync-lock-workspace-versions.ts && bun install --lockfile-only",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
