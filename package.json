{
  "name": "modern-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Universal modern admin panel framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modern-admin/modern-admin.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "!apps/docs",
    "pro-mirror/packages/feature-ai-fill",
    "pro-mirror/packages/feature-logging",
    "pro-mirror/packages/feature-webhooks",
    "pro-mirror/apps/e2e"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:start": "scripts/dev.sh start",
    "dev:stop": "scripts/dev.sh stop",
    "dev:restart": "scripts/dev.sh restart",
    "dev:status": "scripts/dev.sh status",
    "build": "bun run --filter '*' --filter '!@modern-admin/docs' build",
    "test": "bun --filter '*' --filter '!@modern-admin/docs' test",
    "e2e": "bun run --cwd apps/e2e e2e",
    "e2e:pro": "bun run --cwd pro-mirror/apps/e2e e2e",
    "typecheck": "bun run --filter '*' --filter '!@modern-admin/docs' typecheck",
    "lint": "bun run --cwd apps/_shared lint && bun run --cwd apps/api lint && bun run --cwd apps/api-prisma lint && bun run --cwd apps/web lint && bun run --cwd apps/e2e lint",
    "docs:dev": "bun --filter @modern-admin/docs dev",
    "docs:build": "bun --filter @modern-admin/docs build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "changeset": "changeset",
    "version-packages": "bun scripts/ensure-pro-stubs.ts && changeset version && bun install --lockfile-only",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.13",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
